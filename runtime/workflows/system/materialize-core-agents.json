{
  "version": "v1",
  "workflowId": "materialize-core-agents",
  "owner": "ops",
  "templateOwner": "agent-smith",
  "description": "Materialize the core agent workspaces and agent state directories into real OpenClaw runtime paths before enabling multi-agent bring-up.",
  "trigger": {
    "type": "manual",
    "inputs": [
      "agentIds",
      "basePath"
    ]
  },
  "defaults": {
    "basePath": "~/.openclaw",
    "agentIds": [
      "orchestrator",
      "critic",
      "architect",
      "ops",
      "skills-smith",
      "agent-smith",
      "claude-code"
    ]
  },
  "preconditions": [
    "runtime/docs/system/ARCHITECTURE.md exists",
    "runtime/docs/system/GOVERNANCE.md exists",
    "runtime/policies/routing-policy.json exists",
    "runtime/policies/tool-policy-matrix.json exists",
    "runtime/state/agents/catalog.seed.json exists",
    "{{basePath}}/audit/core-agent-materialization.jsonl exists or can be created"
  ],
  "steps": [
    {
      "id": "validate_system_files",
      "action": "assert_files_exist",
      "targets": [
        "runtime/docs/system/ARCHITECTURE.md",
        "runtime/docs/system/GOVERNANCE.md",
        "runtime/policies/routing-policy.json",
        "runtime/policies/tool-policy-matrix.json",
        "runtime/state/agents/catalog.seed.json"
      ]
    },
    {
      "id": "validate_core_templates",
      "action": "assert_files_exist",
      "targets": [
        "runtime/templates/core-agent/AGENTS.md.tpl",
        "runtime/templates/core-agent/SOUL.md.tpl",
        "runtime/templates/core-agent/IDENTITY.md.tpl",
        "runtime/templates/core-agent/TOOLS.md.tpl",
        "runtime/templates/core-agent/BOOT.md.tpl",
        "runtime/templates/core-agent/BOOTSTRAP.md.tpl",
        "runtime/templates/core-agent/HEARTBEAT.md.tpl",
        "runtime/templates/core-agent/MEMORY.md.tpl"
      ]
    },
    {
      "id": "ensure_runtime_parents",
      "action": "mkdir_many",
      "targets": [
        "{{basePath}}/workspaces",
        "{{basePath}}/agents",
        "{{basePath}}/state/agents",
        "{{basePath}}/audit"
      ]
    },
    {
      "id": "ensure_runtime_catalog_exists",
      "action": "copy_file_if_missing",
      "source": "runtime/state/agents/catalog.seed.json",
      "target": "{{basePath}}/state/agents/catalog.json"
    },
    {
      "id": "ensure_audit_file_exists",
      "action": "touch_if_missing",
      "target": "{{basePath}}/audit/core-agent-materialization.jsonl"
    },
    {
      "id": "for_each_agent",
      "action": "for_each",
      "items": "agentIds",
      "steps": [
        {
          "id": "create_workspace_dirs",
          "action": "mkdir_many",
          "targets_template": [
            "{{basePath}}/workspaces/workspace-<item>",
            "{{basePath}}/workspaces/workspace-<item>/memory",
            "{{basePath}}/workspaces/workspace-<item>/docs",
            "{{basePath}}/workspaces/workspace-<item>/state",
            "{{basePath}}/workspaces/workspace-<item>/policies",
            "{{basePath}}/workspaces/workspace-<item>/reports",
            "{{basePath}}/workspaces/workspace-<item>/logs"
          ]
        },
        {
          "id": "create_agent_runtime_dirs",
          "action": "mkdir_many",
          "targets_template": [
            "{{basePath}}/agents/<item>/agent",
            "{{basePath}}/agents/<item>/sessions"
          ]
        },
        {
          "id": "render_root_files",
          "action": "render_templates",
          "source_map": {
            "AGENTS.md": "runtime/templates/core-agent/AGENTS.md.tpl",
            "SOUL.md": "runtime/templates/core-agent/SOUL.md.tpl",
            "IDENTITY.md": "runtime/templates/core-agent/IDENTITY.md.tpl",
            "TOOLS.md": "runtime/templates/core-agent/TOOLS.md.tpl",
            "BOOT.md": "runtime/templates/core-agent/BOOT.md.tpl",
            "BOOTSTRAP.md": "runtime/templates/core-agent/BOOTSTRAP.md.tpl",
            "HEARTBEAT.md": "runtime/templates/core-agent/HEARTBEAT.md.tpl",
            "MEMORY.md": "runtime/templates/core-agent/MEMORY.md.tpl"
          },
          "destination_template": "{{basePath}}/workspaces/workspace-<item>/",
          "variables_template": {
            "agentId": "<item>",
            "workspaceId": "workspace-<item>",
            "roleType": "<item>",
            "roleDescription": "core system role for <item>",
            "responsibilities": "- Follow the role definition registered in ARCHITECTURE.md and the system catalog.",
            "nonResponsibilities": "- Do not assume responsibilities that belong to other agents.",
            "forbiddenActions": "- Do not bypass policy, workflow, sandbox, or explicit role boundaries.",
            "allowedToolDirections": "- Read local files\\n- Write role-local files\\n- Follow policy-approved tool usage",
            "deniedToolDirections": "- Any action outside policy or sandbox\\n- Any action that assumes another agent's authority",
            "heartbeatChecks": "- Root files present\\n- Local state present\\n- No obvious workspace drift\\n- Escalate if missing required files",
            "invariants": "- Maintain role separation\\n- Use file-backed truth sources\\n- Escalate outside-scope work",
            "responsibilitiesSummary": "the role defined for <item> in the system architecture",
            "nonResponsibilitiesSummary": "all responsibilities owned by other agents unless explicitly delegated"
          }
        },
        {
          "id": "seed_local_state",
          "action": "write_json_if_missing",
          "target_template": "{{basePath}}/workspaces/workspace-<item>/state/local-state.json",
          "content_template": {
            "agentId": "<item>",
            "workspaceId": "workspace-<item>",
            "status": "materialized",
            "createdBy": "ops",
            "materializedFrom": "runtime/templates/core-agent",
            "reviewStatus": "pending_review"
          }
        },
        {
          "id": "register_agent_in_catalog",
          "action": "append_or_upsert_json",
          "target": "{{basePath}}/state/agents/catalog.json",
          "record_template": {
            "agentId": "<item>",
            "role": "core_agent",
            "runtime": "acp_if_claude_code_else_native",
            "workspaceId": "workspace-<item>",
            "status": "pending_review"
          }
        },
        {
          "id": "append_audit_entry",
          "action": "append_jsonl",
          "target": "{{basePath}}/audit/core-agent-materialization.jsonl",
          "record_template": {
            "timestamp": "{{now}}",
            "event": "core_agent_materialized",
            "agentId": "<item>",
            "workspaceId": "workspace-<item>",
            "requestedBy": "ops",
            "status": "pending_review"
          }
        }
      ]
    },
    {
      "id": "submit_bootstrap_review",
      "action": "create_review_record",
      "reviewTargetType": "agent",
      "reviewer": "critic",
      "reason": "bootstrap materialization completed for core agents"
    }
  ],
  "successState": "pending_review",
  "failureState": "failed",
  "notes": [
    "This workflow materializes directories and baseline files only.",
    "Claude-code is materialized as a minimum runtime placeholder; ACP connectivity can be validated later.",
    "No heartbeat should be enabled until critic completes bootstrap review."
  ]
}