{
  "tools": {
    "profile": "full",
    "agentToAgent": {
      "enabled": false
    }
  },
  "skills": {
    "load": {
      "watch": true,
      "watchDebounceMs": 250
    },
    "entries": {
      "xuanzhi-control": {
        "enabled": true
      }
    }
  },
  "hooks": {
    "internal": {
      "enabled": true,
      "entries": {
        "command-logger": {
          "enabled": true
        },
        "boot-md": {
          "enabled": true
        },
        "workspace-integrity": {
          "enabled": true
        },
        "ops-action-guard": {
          "enabled": true
        }
      }
    }
  },
  "cron": {
    "enabled": true,
    "store": "~/.openclaw/cron/jobs.json",
    "sessionRetention": "24h",
    "runLog": {
      "maxBytes": "2mb",
      "keepLines": 2000
    }
  },
  "agents": {
    "defaults": {
      "heartbeat": {
        "every": "10m"
      },
      "sandbox": {
        "mode": "non-main",
        "scope": "agent"
      },
      "model": {
        "primary": "openrouter/nvidia/nemotron-3-super-120b-a12b:free",
        "fallbacks": [
          "openrouter/arcee-ai/trinity-mini:free",
          "openrouter/qwen/qwen3-coder:free",
          "openrouter/openai/gpt-oss-120b:free",
          "openrouter/z-ai/glm-4.5-air:free",
          "minimax/MiniMax-M2.5-highspeed",
          "minimax/MiniMax-M2.5"
        ]
      }
    },
    "list": [
      {
        "id": "orchestrator",
        "default": true,
        "workspace": "~/.openclaw/workspace-orchestrator",
        "agentDir": "~/.openclaw/agents/orchestrator/agent",
        "tools": {
          "allow": [
            "read",
            "sessions_list",
            "sessions_history",
            "sessions_send",
            "sessions_spawn",
            "session_status"
          ],
          "deny": [
            "exec",
            "write",
            "edit",
            "browser",
            "canvas"
          ]
        }
      },
      {
        "id": "critic",
        "workspace": "~/.openclaw/workspace-critic",
        "agentDir": "~/.openclaw/agents/critic/agent",
        "tools": {
          "allow": [
            "read",
            "sessions_list",
            "sessions_history"
          ],
          "deny": [
            "exec",
            "write",
            "edit",
            "browser",
            "canvas"
          ]
        }
      },
      {
        "id": "architect",
        "workspace": "~/.openclaw/workspace-architect",
        "agentDir": "~/.openclaw/agents/architect/agent",
        "tools": {
          "allow": [
            "read",
            "write",
            "edit",
            "sessions_list",
            "sessions_history"
          ],
          "deny": [
            "browser",
            "canvas"
          ]
        }
      },
      {
        "id": "ops",
        "workspace": "~/.openclaw/workspace-ops",
        "agentDir": "~/.openclaw/agents/ops/agent",
        "tools": {
          "allow": [
            "read",
            "exec",
            "sessions_list",
            "sessions_history"
          ],
          "deny": [
            "write",
            "edit",
            "browser",
            "canvas"
          ]
        }
      },
      {
        "id": "skills-smith",
        "workspace": "~/.openclaw/workspace-skills-smith",
        "agentDir": "~/.openclaw/agents/skills-smith/agent",
        "tools": {
          "allow": [
            "read",
            "write",
            "edit"
          ],
          "deny": [
            "exec",
            "browser",
            "canvas"
          ]
        }
      },
      {
        "id": "agent-smith",
        "workspace": "~/.openclaw/workspace-agent-smith",
        "agentDir": "~/.openclaw/agents/agent-smith/agent",
        "tools": {
          "allow": [
            "read",
            "write",
            "edit"
          ],
          "deny": [
            "exec",
            "browser",
            "canvas"
          ]
        }
      },
      {
        "id": "claude-code",
        "workspace": "~/.openclaw/workspace-claude-code",
        "agentDir": "~/.openclaw/agents/claude-code/agent",
        "sandbox": {
          "mode": "off"
        },
        "tools": {
          "allow": [
            "read",
            "write",
            "edit",
            "exec",
            "sessions_list",
            "sessions_history"
          ],
          "deny": [
            "canvas"
          ]
        }
      }
    ]
  },
  "models": {
    "mode": "merge",
    "providers": {
      "minimax": {
        "baseUrl": "https://api.minimaxi.com/anthropic",
        "api": "anthropic-messages",
        "apiKey": "${MINIMAX_API_KEY}",
        "models": [
          {
            "id": "MiniMax-M2.5",
            "name": "MiniMax M2.5",
            "reasoning": true,
            "input": [
              "text"
            ],
            "cost": {
              "input": 0.3,
              "output": 1.2,
              "cacheRead": 0.03,
              "cacheWrite": 0.12
            },
            "contextWindow": 200000,
            "maxTokens": 8192
          },
          {
            "id": "MiniMax-M2.5-highspeed",
            "name": "MiniMax M2.5 Highspeed",
            "reasoning": true,
            "input": [
              "text"
            ],
            "cost": {
              "input": 0.3,
              "output": 1.2,
              "cacheRead": 0.03,
              "cacheWrite": 0.12
            },
            "contextWindow": 200000,
            "maxTokens": 8192
          }
        ]
      }
    }
  },
  "bindings": [],
  "channels": {}
}
