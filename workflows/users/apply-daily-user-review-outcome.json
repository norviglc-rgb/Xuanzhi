{
  "version": "v1",
  "workflowId": "apply-daily-user-review-outcome",
  "owner": "ops",
  "description": "Apply critic review outcome for a pending daily user, close the handoff loop, and write final status back to state/users.",
  "trigger": {
    "type": "manual_or_review_event",
    "inputs": ["requestId", "userId", "reviewId", "reviewStatus", "reviewer", "findings"]
  },
  "preconditions": [
    "schemas/review.schema.json exists",
    "state/users/index.json exists",
    "state/audit/review-gate.jsonl exists"
  ],
  "steps": [
    {
      "id": "build_review_outcome_record",
      "action": "transform_input",
      "inputs": ["requestId", "userId", "reviewId", "reviewStatus", "reviewer", "findings"],
      "output": "reviewOutcomeRecord",
      "rules": [
        "reviewId = <reviewId>",
        "targetType = user_instance",
        "targetRef = daily-<userId>",
        "reviewer = <reviewer>",
        "status = <reviewStatus>",
        "findings = <findings>"
      ]
    },
    {
      "id": "validate_review_outcome_record",
      "action": "check_schema",
      "schema": "schemas/review.schema.json",
      "input": "reviewOutcomeRecord"
    },
    {
      "id": "build_user_final_status_patch",
      "action": "transform_input",
      "inputs": ["userId", "reviewStatus", "reviewId"],
      "output": "userFinalStatusPatch",
      "rules": [
        "userId = <userId>",
        "status = if <reviewStatus> == approved then active else if <reviewStatus> == rejected then disabled else pending_review",
        "reviewId = <reviewId>"
      ]
    },
    {
      "id": "build_closure_record",
      "action": "transform_input",
      "inputs": ["requestId", "userId", "reviewId", "reviewStatus"],
      "output": "closureRecord",
      "rules": [
        "event = daily_user_review_closure",
        "requestId = <requestId>",
        "userId = <userId>",
        "reviewId = <reviewId>",
        "startedBy = critic",
        "handledBy = ops",
        "closedBy = apply-daily-user-review-outcome",
        "finalStatus = if <reviewStatus> == approved then active else if <reviewStatus> == rejected then disabled else pending_review",
        "nextStep = if <reviewStatus> == needs_changes then rerun create-daily-user after fixes else none"
      ]
    },
    {
      "id": "write_user_final_status",
      "action": "upsert_json",
      "target": "state/users/index.json",
      "input": "userFinalStatusPatch",
      "mergeKey": ["userId"]
    },
    {
      "id": "write_review_outcome_audit",
      "action": "append_jsonl",
      "target": "state/audit/review-gate.jsonl",
      "input": "reviewOutcomeRecord"
    },
    {
      "id": "write_closure_audit",
      "action": "append_jsonl",
      "target": "state/audit/review-gate.jsonl",
      "input": "closureRecord"
    }
  ],
  "successState": "review_outcome_applied",
  "failureState": "failed"
}
