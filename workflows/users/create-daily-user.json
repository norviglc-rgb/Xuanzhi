{
  "version": "v1",
  "workflowId": "create-daily-user",
  "owner": "agent-smith",
  "description": "Materialize a daily user agent/workspace via agent-smith skill, then write runtime state, audit, and pending-review records.",
  "trigger": {
    "type": "manual_or_external_event",
    "inputs": ["requestId", "userId", "displayName", "persona", "bindings"]
  },
  "preconditions": [
    "schemas/user-profile.schema.json exists",
    "schemas/review.schema.json exists",
    "policies/routing-policy.json ownership_routes.create_daily_user_runtime exists",
    "policies/routing-policy.json ownership_routes.create_daily_user_runtime.target == agent-smith",
    "policies/routing-policy.json ownership_routes.create_agent exists",
    "state/skills/catalog.json contains skillId=agent-smith-daily-user-materialization",
    "state/users/index.json exists",
    "state/agents/catalog.json exists",
    "state/audit/user-provision.jsonl exists",
    "state/audit/review-gate.jsonl exists",
    "workspace-agent-smith exists"
  ],
  "steps": [
    {
      "id": "create_workspace",
      "action": "mkdir_many",
      "targets_template": [
        "workspace-daily-<userId>",
        "workspace-daily-<userId>/memory",
        "workspace-daily-<userId>/docs",
        "workspace-daily-<userId>/state"
      ]
    },
    {
      "id": "create_agent_runtime",
      "action": "mkdir_many",
      "targets_template": [
        "agents/daily-<userId>/agent",
        "agents/daily-<userId>/sessions"
      ]
    },
    {
      "id": "run_materialization_skill",
      "action": "invoke_skill",
      "targetAgent": "agent-smith",
      "skillId": "agent-smith-daily-user-materialization",
      "operation": "materialize_daily_user_runtime",
      "inputs": ["requestId", "userId", "displayName", "persona", "bindings"],
      "outputs": ["materializationReport"]
    },
    {
      "id": "verify_materialization_report",
      "action": "check_required_fields",
      "input": "materializationReport",
      "requiredFields": ["workspaceId", "agentId", "status", "artifacts"],
      "requiredValues": ["status=ready"]
    },
    {
      "id": "verify_daily_workspace_contract",
      "action": "check_files_exist",
      "targetTemplate": "workspace-daily-<userId>",
      "requiredFiles": [
        "AGENTS.md",
        "SOUL.md",
        "USER.md",
        "IDENTITY.md",
        "TOOLS.md",
        "HEARTBEAT.md",
        "BOOT.md",
        "BOOTSTRAP.md",
        "MEMORY.md"
      ]
    },
    {
      "id": "build_user_profile_record",
      "action": "transform_input",
      "inputs": ["userId", "displayName", "persona", "bindings"],
      "output": "userProfileRecord",
      "rules": [
        "dailyAgentId = daily-<userId>",
        "workspaceId = workspace-daily-<userId>",
        "capabilityProfile = daily_light",
        "status = pending_review"
      ]
    },
    {
      "id": "validate_user_profile",
      "action": "check_schema",
      "schema": "schemas/user-profile.schema.json",
      "input": "userProfileRecord"
    },
    {
      "id": "register_user",
      "action": "upsert_json",
      "target": "state/users/index.json",
      "input": "userProfileRecord",
      "mergeKey": ["userId"]
    },
    {
      "id": "build_daily_agent_record",
      "action": "transform_input",
      "inputs": ["userId"],
      "output": "dailyAgentRecord",
      "rules": [
        "agentId = daily-<userId>",
        "role = daily_user_domain",
        "runtime = native",
        "workspaceId = workspace-daily-<userId>",
        "status = pending_review"
      ]
    },
    {
      "id": "register_agent",
      "action": "upsert_json",
      "target": "state/agents/catalog.json",
      "path": "agents",
      "input": "dailyAgentRecord",
      "mergeKey": ["agentId"]
    },
    {
      "id": "build_binding_entries",
      "action": "transform_input",
      "input": "bindings",
      "output": "bindingEntries",
      "rules": [
        "for each accountId in bindings.accountIds -> create {userId, agentId: daily-<userId>, match:{accountId}}",
        "for each channelId in bindings.channelIds -> create {userId, agentId: daily-<userId>, match:{channelId}}"
      ]
    },
    {
      "id": "update_bindings",
      "action": "upsert_json",
      "target": "openclaw.json",
      "path": "bindings",
      "input": "bindingEntries",
      "mergeKey": ["userId", "agentId", "match.accountId", "match.channelId"]
    },
    {
      "id": "build_user_provision_audit_record",
      "action": "transform_input",
      "inputs": ["requestId", "userId", "dailyAgentRecord.agentId", "dailyAgentRecord.workspaceId"],
      "output": "userProvisionAuditRecord",
      "rules": [
        "event = user_provision_submitted",
        "requestId = <requestId>",
        "userId = <userId>",
        "agentId = <dailyAgentRecord.agentId>",
        "workspaceId = <dailyAgentRecord.workspaceId>",
        "owner = agent-smith",
        "status = pending_review",
        "createdAt = now",
        "updatedAt = now"
      ]
    },
    {
      "id": "write_audit",
      "action": "append_jsonl",
      "target": "state/audit/user-provision.jsonl",
      "input": "userProvisionAuditRecord"
    },
    {
      "id": "build_review_record",
      "action": "transform_input",
      "inputs": ["requestId", "userId"],
      "output": "reviewRecord",
      "rules": [
        "reviewId = review-<requestId>-<userId>",
        "targetType = user_instance",
        "targetRef = daily-<userId>",
        "reviewer = critic",
        "status = pending",
        "lifecyclePhase = submitted",
        "flow.startedBy = agent-smith",
        "flow.routedBy = orchestrator",
        "flow.handledBy = agent-smith",
        "flow.closedBy = apply-daily-user-review-outcome",
        "flow.nextStep = wait_critic_review",
        "createdAt = now",
        "updatedAt = now"
      ]
    },
    {
      "id": "validate_review_record",
      "action": "check_schema",
      "schema": "schemas/review.schema.json",
      "input": "reviewRecord"
    },
    {
      "id": "submit_for_review",
      "action": "append_jsonl",
      "target": "state/audit/review-gate.jsonl",
      "input": "reviewRecord"
    },
    {
      "id": "build_user_pending_review_patch",
      "action": "transform_input",
      "inputs": ["userId", "reviewRecord.reviewId"],
      "output": "userPendingReviewPatch",
      "rules": [
        "userId = <userId>",
        "status = pending_review",
        "reviewId = <reviewRecord.reviewId>"
      ]
    },
    {
      "id": "write_user_pending_review_state",
      "action": "upsert_json",
      "target": "state/users/index.json",
      "input": "userPendingReviewPatch",
      "mergeKey": ["userId"]
    }
  ],
  "successState": "pending_review",
  "failureState": "failed"
  ,
  "followup": {
    "onReviewDecision": "workflows/users/apply-daily-user-review-outcome.json"
  }
}
