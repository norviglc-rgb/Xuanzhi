{
  "version": "v1",
  "workflowId": "validate-ownership-and-closure",
  "owner": "critic",
  "description": "Proactively validate ownership routing and closure-chain integrity for agent/skill/daily lifecycle workflows.",
  "trigger": {
    "type": "manual_or_scheduled",
    "inputs": ["requestId", "invokedBy"]
  },
  "preconditions": [
    "policies/routing-policy.json exists",
    "policies/routing-policy.json proactive_validation exists",
    "schemas/review.schema.json exists",
    "schemas/task.schema.json exists",
    "state/router/tasks.json exists",
    "state/audit/review-gate.jsonl exists"
  ],
  "steps": [
    {
      "id": "check_ownership_routes_exist",
      "action": "check_json_paths",
      "target": "policies/routing-policy.json",
      "output": "ownershipCheck",
      "requiredPaths": [
        "ownership_routes.create_agent.target",
        "ownership_routes.create_skill.target",
        "ownership_routes.review_outcome_apply.target",
        "closure_routes.daily_user_lifecycle",
        "closure_routes.agent_or_skill_creation"
      ]
    },
    {
      "id": "check_smith_target_values",
      "action": "check_text_patterns",
      "output": "smithTargetCheck",
      "targets": [
        "policies/routing-policy.json"
      ],
      "requiredPatterns": [
        "\"create_agent\"",
        "\"target\": \"agent-smith\"",
        "\"create_skill\"",
        "\"target\": \"skills-smith\""
      ]
    },
    {
      "id": "check_create_apply_workflow_pairs",
      "action": "check_files_exist",
      "output": "pairCheck",
      "requiredFiles": [
        "workflows/system/create-agent.json",
        "workflows/system/apply-agent-review-outcome.json",
        "workflows/skills/create-skill.json",
        "workflows/skills/apply-skill-review-outcome.json",
        "workflows/users/create-daily-user.json",
        "workflows/users/apply-daily-user-review-outcome.json",
        "workflows/memory/promote.json",
        "workflows/memory/apply-memory-promotion-review-outcome.json"
      ]
    },
    {
      "id": "check_parallel_research_route_reachable",
      "action": "check_text_patterns",
      "output": "routeReachabilityCheck",
      "targets": [
        "policies/routing-policy.json"
      ],
      "requiredPatterns": [
        "\"parallel_research\"",
        "\"target\": \"orchestrator\""
      ]
    },
    {
      "id": "check_state_gates_in_apply_workflows",
      "action": "check_text_patterns",
      "output": "gateCheck",
      "targets": [
        "workflows/system/apply-agent-review-outcome.json",
        "workflows/skills/apply-skill-review-outcome.json",
        "workflows/users/apply-daily-user-review-outcome.json"
      ],
      "requiredPatterns": [
        "assert_current_status",
        "requiredStatus"
      ]
    },
    {
      "id": "build_validation_summary",
      "action": "summarize_checks",
      "inputs": ["ownershipCheck", "smithTargetCheck", "pairCheck", "routeReachabilityCheck", "gateCheck"],
      "output": "validationSummary",
      "rules": [
        "hasBlockingIssues = any_check_failed",
        "severity = if hasBlockingIssues then critical else info",
        "status = if hasBlockingIssues then needs_changes else approved",
        "summary = if hasBlockingIssues then ownership_or_closure_drift_detected else ownership_and_closure_valid"
      ]
    },
    {
      "id": "build_validation_review_record",
      "action": "transform_input",
      "inputs": ["requestId", "invokedBy", "validationSummary"],
      "output": "validationReviewRecord",
      "rules": [
        "reviewId = review-ownership-closure-<requestId>",
        "targetType = policy_change",
        "targetRef = ownership_and_closure_rules",
        "reviewer = critic",
        "status = <validationSummary.status>",
        "lifecyclePhase = closure",
        "flow.startedBy = critic",
        "flow.routedBy = orchestrator",
        "flow.handledBy = critic",
        "flow.closedBy = validate-ownership-and-closure",
        "flow.nextStep = if <validationSummary.status> == needs_changes then fix_workflows_and_rerun_validation else none",
        "findings = [{severity:<validationSummary.severity>, message:<validationSummary.summary>}]",
        "createdAt = now",
        "updatedAt = now"
      ]
    },
    {
      "id": "validate_validation_review_record",
      "action": "check_schema",
      "schema": "schemas/review.schema.json",
      "input": "validationReviewRecord"
    },
    {
      "id": "build_remediation_task",
      "action": "transform_input",
      "inputs": ["requestId", "validationSummary", "validationReviewRecord.reviewId"],
      "output": "remediationTask",
      "rules": [
        "taskId = task-ownership-closure-remediate-<requestId>",
        "title = Fix ownership/closure drift from proactive validation",
        "type = review_or_signoff",
        "source.kind = workflow",
        "source.ref = validate-ownership-and-closure",
        "owner = critic",
        "status = new",
        "complexity = normal",
        "route.targetAgent = critic",
        "route.runtime = native",
        "route.reason = [proactive_validation_failed, ownership_or_closure_drift_detected]",
        "artifacts = [policies/routing-policy.json, workflows/system/validate-ownership-and-closure.json, state/audit/review-gate.jsonl, <validationReviewRecord.reviewId>]",
        "createdAt = now",
        "updatedAt = now"
      ]
    },
    {
      "id": "validate_remediation_task",
      "action": "check_schema",
      "schema": "schemas/task.schema.json",
      "input": "remediationTask"
    },
    {
      "id": "write_remediation_task",
      "action": "upsert_json",
      "target": "state/router/tasks.json",
      "path": "tasks",
      "input": "remediationTask",
      "mergeKey": ["taskId"],
      "when": "validationSummary.status == needs_changes && policies.routing_policy.proactive_validation.emit_runtime_task_on_failure == true"
    },
    {
      "id": "write_validation_audit",
      "action": "append_jsonl",
      "target": "state/audit/review-gate.jsonl",
      "input": "validationReviewRecord"
    }
  ],
  "successState": "validated",
  "failureState": "failed"
}
