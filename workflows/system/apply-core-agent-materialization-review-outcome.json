{
  "version": "v1",
  "workflowId": "apply-core-agent-materialization-review-outcome",
  "owner": "ops",
  "description": "Apply critic review outcome for core-agent materialization and close pending_review status for the involved core agents.",
  "trigger": {
    "type": "manual_or_review_event",
    "inputs": ["requestId", "agentIds", "reviewId", "reviewStatus", "reviewer", "findings"]
  },
  "preconditions": [
    "schemas/review.schema.json exists",
    "state/agents/catalog.json exists",
    "state/audit/review-gate.jsonl exists"
  ],
  "steps": [
    {
      "id": "build_core_materialization_review_outcome_record",
      "action": "transform_input",
      "inputs": ["requestId", "reviewId", "reviewStatus", "reviewer", "findings"],
      "output": "reviewOutcomeRecord",
      "rules": [
        "reviewId = <reviewId>",
        "targetType = policy_change",
        "targetRef = core-agent-materialization-<requestId>",
        "reviewer = <reviewer>",
        "status = <reviewStatus>",
        "lifecyclePhase = decision",
        "flow.startedBy = ops",
        "flow.routedBy = orchestrator",
        "flow.handledBy = ops",
        "flow.closedBy = apply-core-agent-materialization-review-outcome",
        "flow.nextStep = if <reviewStatus> == needs_changes then rerun materialize-core-agents after fixes else none",
        "findings = <findings>",
        "createdAt = now",
        "updatedAt = now"
      ]
    },
    {
      "id": "validate_review_outcome_record",
      "action": "check_schema",
      "schema": "schemas/review.schema.json",
      "input": "reviewOutcomeRecord"
    },
    {
      "id": "build_core_agent_final_status_patches",
      "action": "transform_input",
      "inputs": ["agentIds", "reviewStatus", "reviewId"],
      "output": "coreAgentFinalStatusPatches",
      "rules": [
        "for each item in agentIds -> create {agentId:<item>, status:if <reviewStatus> == approved then active else if <reviewStatus> == rejected then blocked else pending_review, reviewId:<reviewId>}"
      ]
    },
    {
      "id": "write_core_agent_final_statuses",
      "action": "upsert_json",
      "target": "state/agents/catalog.json",
      "path": "agents",
      "input": "coreAgentFinalStatusPatches",
      "mergeKey": ["agentId"]
    },
    {
      "id": "build_closure_record",
      "action": "transform_input",
      "inputs": ["requestId", "reviewId", "reviewStatus"],
      "output": "closureRecord",
      "rules": [
        "reviewId = <reviewId>",
        "targetType = policy_change",
        "targetRef = core-agent-materialization-<requestId>",
        "reviewer = critic",
        "status = <reviewStatus>",
        "lifecyclePhase = closure",
        "flow.startedBy = ops",
        "flow.routedBy = orchestrator",
        "flow.handledBy = ops",
        "flow.closedBy = apply-core-agent-materialization-review-outcome",
        "flow.nextStep = if <reviewStatus> == needs_changes then rerun materialize-core-agents after fixes else none",
        "createdAt = now",
        "updatedAt = now"
      ]
    },
    {
      "id": "validate_closure_record",
      "action": "check_schema",
      "schema": "schemas/review.schema.json",
      "input": "closureRecord"
    },
    {
      "id": "write_review_outcome_audit",
      "action": "append_jsonl",
      "target": "state/audit/review-gate.jsonl",
      "input": "reviewOutcomeRecord"
    },
    {
      "id": "write_closure_audit",
      "action": "append_jsonl",
      "target": "state/audit/review-gate.jsonl",
      "input": "closureRecord"
    }
  ],
  "successState": "review_outcome_applied",
  "failureState": "failed"
}
