{
  "version": "v1",
  "workflowId": "apply-agent-review-outcome",
  "owner": "ops",
  "description": "Apply critic review outcome for a pending agent and write final status into state/agents.",
  "trigger": {
    "type": "manual_or_review_event",
    "inputs": ["requestId", "agentId", "reviewId", "reviewStatus", "reviewer", "findings"]
  },
  "preconditions": [
    "schemas/review.schema.json exists",
    "policies/routing-policy.json closure_routes.agent_or_skill_creation exists",
    "state/agents/catalog.json exists",
    "state/audit/review-gate.jsonl exists"
  ],
  "steps": [
    {
      "id": "build_agent_review_decision_record",
      "action": "transform_input",
      "inputs": ["agentId", "reviewId", "reviewStatus", "reviewer", "findings"],
      "output": "reviewDecisionRecord",
      "rules": [
        "reviewId = <reviewId>",
        "targetType = agent",
        "targetRef = <agentId>",
        "reviewer = <reviewer>",
        "status = <reviewStatus>",
        "lifecyclePhase = decision",
        "flow.startedBy = orchestrator",
        "flow.routedBy = orchestrator",
        "flow.handledBy = agent-smith",
        "flow.closedBy = apply-agent-review-outcome",
        "flow.nextStep = if <reviewStatus> == needs_changes then rerun create-agent after fixes else none",
        "findings = <findings>",
        "createdAt = now",
        "updatedAt = now"
      ]
    },
    {
      "id": "validate_agent_review_decision_record",
      "action": "check_schema",
      "schema": "schemas/review.schema.json",
      "input": "reviewDecisionRecord"
    },
    {
      "id": "build_agent_final_status_patch",
      "action": "transform_input",
      "inputs": ["agentId", "reviewStatus", "reviewId"],
      "output": "agentFinalStatusPatch",
      "rules": [
        "agentId = <agentId>",
        "status = if <reviewStatus> == approved then active else if <reviewStatus> == rejected then blocked else pending_review",
        "reviewId = <reviewId>"
      ]
    },
    {
      "id": "write_agent_final_status",
      "action": "upsert_json",
      "target": "state/agents/catalog.json",
      "input": "agentFinalStatusPatch",
      "mergeKey": ["agentId"]
    },
    {
      "id": "write_agent_review_decision_audit",
      "action": "append_jsonl",
      "target": "state/audit/review-gate.jsonl",
      "input": "reviewDecisionRecord"
    }
  ],
  "successState": "review_outcome_applied",
  "failureState": "failed"
}
