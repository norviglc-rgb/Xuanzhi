{
  "version": "v1",
  "workflowId": "memory-promote",
  "owner": "critic",
  "description": "Promote validated memory from daily notes into MEMORY.md with audit and review trace.",
  "trigger": {
    "type": "manual_or_heartbeat",
    "inputs": ["requestId", "workspaceId", "candidateContent", "reason"]
  },
  "preconditions": [
    "policies/memory-policy.json exists",
    "workspace target exists"
  ],
  "steps": [
    { "id": "validate_candidate", "action": "check_policy", "policy": "policies/memory-policy.json" },
    { "id": "append_long_term_memory", "action": "append_markdown_section", "target_template": "workspace-<workspaceId>/MEMORY.md" },
    { "id": "write_audit_record", "action": "append_jsonl", "target": "logs/audit/memory-promotion.jsonl" },
    { "id": "create_review_record", "action": "append_jsonl", "target": "logs/audit/review-gate.jsonl" }
  ],
  "successState": "promoted",
  "failureState": "rejected"
}
