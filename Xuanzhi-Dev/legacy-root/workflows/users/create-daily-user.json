{
  "version": "v1",
  "workflowId": "create-daily-user",
  "owner": "ops",
  "templateOwner": "agent-smith",
  "description": "Create a per-user daily agent instance from the runtime daily-template and register it into live runtime state.",
  "trigger": {
    "type": "manual_or_external_event",
    "inputs": [
      "userId",
      "displayName",
      "persona",
      "bindings",
      "preferences",
      "basePath"
    ]
  },
  "defaults": {
    "basePath": "~/.openclaw"
  },
  "preconditions": [
    "templates/daily-template exists",
    "schemas/user-profile.schema.json exists",
    "{{basePath}}/state/users/index.json exists or can be copied from state/users/index.json",
    "{{basePath}}/state/agents/catalog.json exists or can be copied from state/agents/catalog.json",
    "{{basePath}}/audit/user-provision.jsonl exists or can be created"
  ],
  "steps": [
    {
      "id": "validate_input",
      "action": "validate_against_schema",
      "schema": "schemas/user-profile.schema.json"
    },
    {
      "id": "materialize_agent_id",
      "action": "render_string",
      "template": "daily-<userId>"
    },
    {
      "id": "materialize_workspace_id",
      "action": "render_string",
      "template": "workspace-daily-<userId>"
    },
    {
      "id": "ensure_runtime_parents",
      "action": "mkdir_many",
      "targets": [
        "{{basePath}}/workspaces",
        "{{basePath}}/agents",
        "{{basePath}}/state/users",
        "{{basePath}}/state/agents",
        "{{basePath}}/audit"
      ]
    },
    {
      "id": "ensure_user_index_exists",
      "action": "copy_file_if_missing",
      "source": "state/users/index.json",
      "target": "{{basePath}}/state/users/index.json"
    },
    {
      "id": "ensure_agent_catalog_exists",
      "action": "copy_file_if_missing",
      "source": "state/agents/catalog.json",
      "target": "{{basePath}}/state/agents/catalog.json"
    },
    {
      "id": "ensure_audit_file_exists",
      "action": "touch_if_missing",
      "target": "{{basePath}}/audit/user-provision.jsonl"
    },
    {
      "id": "copy_template",
      "action": "copy_directory_template",
      "source": "templates/daily-template",
      "target": "{{basePath}}/workspaces/workspace-daily-<userId>"
    },
    {
      "id": "render_profile",
      "action": "render_json_template",
      "target": "{{basePath}}/workspaces/workspace-daily-<userId>/profile.json"
    },
    {
      "id": "render_root_files",
      "action": "render_workspace_templates",
      "targets": [
        "AGENTS.md",
        "SOUL.md",
        "USER.md",
        "IDENTITY.md",
        "TOOLS.md",
        "HEARTBEAT.md",
        "BOOT.md",
        "BOOTSTRAP.md",
        "MEMORY.md"
      ],
      "destination": "{{basePath}}/workspaces/workspace-daily-<userId>/"
    },
    {
      "id": "create_agent_runtime_dirs",
      "action": "mkdir_many",
      "targets": [
        "{{basePath}}/agents/daily-<userId>/agent",
        "{{basePath}}/agents/daily-<userId>/sessions"
      ]
    },
    {
      "id": "initialize_memory_dir",
      "action": "mkdir",
      "target": "{{basePath}}/workspaces/workspace-daily-<userId>/memory"
    },
    {
      "id": "register_user_state",
      "action": "append_or_upsert_json",
      "target": "{{basePath}}/state/users/index.json"
    },
    {
      "id": "register_agent_catalog",
      "action": "append_or_upsert_json",
      "target": "{{basePath}}/state/agents/catalog.json"
    },
    {
      "id": "update_bindings",
      "action": "update_binding_config"
    },
    {
      "id": "git_commit",
      "action": "git_commit",
      "message_template": "provision daily agent for <userId>"
    },
    {
      "id": "write_audit",
      "action": "append_jsonl",
      "target": "{{basePath}}/audit/user-provision.jsonl"
    },
    {
      "id": "submit_for_review",
      "action": "create_review_record",
      "reviewTargetType": "user_instance",
      "reviewer": "critic"
    }
  ],
  "successState": "pending_review",
  "failureState": "failed",
  "notes": [
    "This workflow writes to live runtime state under {{basePath}}/state, not to runtime seed files.",
    "The daily workspace is materialized into {{basePath}}/workspaces/workspace-daily-<userId>.",
    "Bindings update remains environment-specific and should be validated before enabling production traffic."
  ]
}
