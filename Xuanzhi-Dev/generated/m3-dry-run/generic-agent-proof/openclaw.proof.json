{
  "tools": {
    "profile": "coding",
    "agentToAgent": {
      "enabled": false
    }
  },
  "skills": {
    "load": {
      "watch": true,
      "watchDebounceMs": 250
    },
    "entries": {
      "xuanzhi-control": {
        "enabled": true
      }
    }
  },
  "hooks": {
    "internal": {
      "enabled": true,
      "entries": {
        "command-logger": {
          "enabled": true
        },
        "boot-md": {
          "enabled": true
        },
        "workspace-integrity": {
          "enabled": true
        },
        "ops-action-guard": {
          "enabled": true
        }
      }
    }
  },
  "cron": {
    "enabled": true,
    "store": "~/.openclaw/cron/jobs.json",
    "sessionRetention": "24h",
    "runLog": {
      "maxBytes": "2mb",
      "keepLines": 2000
    }
  },
  "agents": {
    "defaults": {
      "heartbeat": {
        "every": "0m"
      },
      "sandbox": {
        "mode": "non-main",
        "scope": "agent"
      }
    },
    "list": [
      {
        "id": "orchestrator",
        "default": true,
        "workspace": "~/.openclaw/workspace-orchestrator",
        "agentDir": "~/.openclaw/agents/orchestrator/agent",
        "tools": {
          "allow": [
            "read",
            "sessions_list",
            "sessions_history",
            "sessions_send",
            "sessions_spawn",
            "session_status"
          ],
          "deny": [
            "exec",
            "write",
            "edit",
            "apply_patch",
            "browser",
            "canvas"
          ]
        }
      },
      {
        "id": "critic",
        "workspace": "~/.openclaw/workspace-critic",
        "agentDir": "~/.openclaw/agents/critic/agent",
        "tools": {
          "allow": [
            "read",
            "sessions_list",
            "sessions_history"
          ],
          "deny": [
            "exec",
            "write",
            "edit",
            "apply_patch",
            "browser",
            "canvas"
          ]
        }
      },
      {
        "id": "architect",
        "workspace": "~/.openclaw/workspace-architect",
        "agentDir": "~/.openclaw/agents/architect/agent",
        "tools": {
          "allow": [
            "read",
            "write",
            "edit",
            "apply_patch",
            "sessions_list",
            "sessions_history"
          ],
          "deny": [
            "browser",
            "canvas"
          ]
        }
      },
      {
        "id": "ops",
        "workspace": "~/.openclaw/workspace-ops",
        "agentDir": "~/.openclaw/agents/ops/agent",
        "tools": {
          "allow": [
            "read",
            "exec",
            "sessions_list",
            "sessions_history"
          ],
          "deny": [
            "write",
            "edit",
            "apply_patch",
            "browser",
            "canvas"
          ]
        }
      },
      {
        "id": "skills-smith",
        "workspace": "~/.openclaw/workspace-skills-smith",
        "agentDir": "~/.openclaw/agents/skills-smith/agent",
        "tools": {
          "allow": [
            "read",
            "write",
            "edit",
            "apply_patch"
          ],
          "deny": [
            "exec",
            "browser",
            "canvas"
          ]
        }
      },
      {
        "id": "agent-smith",
        "workspace": "~/.openclaw/workspace-agent-smith",
        "agentDir": "~/.openclaw/agents/agent-smith/agent",
        "tools": {
          "allow": [
            "read",
            "write",
            "edit",
            "apply_patch"
          ],
          "deny": [
            "exec",
            "browser",
            "canvas"
          ]
        }
      },
      {
        "id": "claude-code",
        "workspace": "~/.openclaw/workspace-claude-code",
        "agentDir": "~/.openclaw/agents/claude-code/agent",
        "sandbox": {
          "mode": "off"
        },
        "tools": {
          "allow": [
            "read",
            "write",
            "edit",
            "apply_patch",
            "exec",
            "sessions_list",
            "sessions_history"
          ],
          "deny": [
            "canvas"
          ]
        }
      },
      {
        "id": "proof-agent",
        "workspace": "~/.openclaw/workspace-proof-agent",
        "agentDir": "~/.openclaw/agents/proof-agent/agent",
        "tools": {
          "allow": [
            "read"
          ],
          "deny": [
            "exec",
            "write",
            "edit",
            "apply_patch",
            "browser",
            "canvas"
          ]
        }
      }
    ]
  },
  "bindings": [],
  "channels": {}
}
